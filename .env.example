APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production hospitaliere:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://votre-domaine-hopital.example
# DB_USERNAME=polyclique_app
# DB_PASSWORD=mot-de-passe-long-et-unique
# QUEUE_CONNECTION=database
# CACHE_STORE=database
# SESSION_DRIVER=database
# SESSION_ENCRYPT=true
# LOG_LEVEL=info
# CORS_ALLOWED_ORIGINS=https://app-mobile-ou-web-hopital.example
# Hebergement: utiliser une infrastructure conforme au cadre applicable aux donnees de sante.

SANCTUM_EXPIRATION=10080
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MOBILE_MONEY_TIMEOUT=30
MOBILE_MONEY_CALLBACK_URL="${APP_URL}/api/mobile-money/callback"

ORANGE_MONEY_ENDPOINT=
ORANGE_MONEY_CLIENT_ID=orange-client-id-demo
ORANGE_MONEY_CLIENT_SECRET=orange-client-secret-demo
ORANGE_MONEY_MERCHANT_ID=orange-merchant-demo
ORANGE_MONEY_CDF_ACCOUNT=orange-cdf-account-demo
ORANGE_MONEY_USD_ACCOUNT=orange-usd-account-demo

AIRTEL_MONEY_ENDPOINT=
AIRTEL_MONEY_CLIENT_ID=airtel-client-id-demo
AIRTEL_MONEY_CLIENT_SECRET=airtel-client-secret-demo
AIRTEL_MONEY_MERCHANT_ID=airtel-merchant-demo
AIRTEL_MONEY_CDF_ACCOUNT=airtel-cdf-account-demo
AIRTEL_MONEY_USD_ACCOUNT=airtel-usd-account-demo

MPESA_ENDPOINT=
MPESA_CLIENT_ID=mpesa-client-id-demo
MPESA_CLIENT_SECRET=mpesa-client-secret-demo
MPESA_MERCHANT_ID=mpesa-merchant-demo
MPESA_CDF_ACCOUNT=mpesa-cdf-account-demo
MPESA_USD_ACCOUNT=mpesa-usd-account-demo

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
