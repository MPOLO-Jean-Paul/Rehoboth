{
  "cli": {
    "version": ">= 5.9.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "developmentClient": false,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ANDROID_NDK_VERSION": "26.1.10909125",
        "NODE_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
